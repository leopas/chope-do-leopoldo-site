# App
APP_ENV=local
APP_NAME=chope-do-leopoldo-site
API_PREFIX=/api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Database — Azure (PostgreSQL ou MySQL)
# Deixe DATABASE_URL vazio em dev local com mocks no frontend.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST.postgres.database.azure.com:5432/DBNAME?sslmode=require
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST.mysql.database.azure.com:3306/DBNAME
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=/app/certs/azure-db-ca.pem
DB_SSL_MODE=verify-full

# Auth (CRP-008) — obrigatório para /api/admin/*
JWT_SECRET=change-me-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-me

# Media (CRP-006)
MEDIA_STORAGE_PROVIDER=local
MAX_UPLOAD_MB=5
# UPLOADS_DIR=/app/app/static/uploads
# MEDIA_STORAGE_PROVIDER=azure_blob
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=chope-media
# AZURE_STORAGE_ACCOUNT_URL=https://ACCOUNT.blob.core.windows.net
